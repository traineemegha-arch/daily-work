
public class student {
private int id;
private int marks;
private String name;
public student(int id, int marks, String name) {
	super();
	this.id = id;
	this.marks = marks;
	this.name = name;
}
void display() {
	System.out.println("id: "+this.id+" marks: "+this.marks+" name: "+this.name);
}
public static void main(String[]args) {
	student s1= new student(1,22,"megha");
	s1.display();
}
}

