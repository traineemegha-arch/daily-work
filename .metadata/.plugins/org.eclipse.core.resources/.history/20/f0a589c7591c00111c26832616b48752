	 static boolean evenOrodd(int number) {
		return number%2==0;
		
	}
	static void stars(int rows) {
		for(int i=rows;i>=1;i--) {
			for(int j=1;j<=i;j++) {
				System.out.print("*");	
			}
			System.out.println();
		}
			
			
	}
	static void largest(int a,int b,int c) {
		if(a>b&&b>c) {
			System.out.println("largest:" + a);
		}
		else if(b>a&& b>c) {
			System.out.println("largest:" + b);
		}
		else {
			System.out.println("largest:" + c);
		}
	}

	

}