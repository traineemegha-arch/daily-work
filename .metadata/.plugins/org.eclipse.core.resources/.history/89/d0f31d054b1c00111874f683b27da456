	 static boolean evenOrodd(int number) {
		return number%2==0;
		
	}
	static void stars(int r) {
		for(int i=r;i<=0;i--) {
			for(int j=r;j<=i-1;j++) {
				System.out.print("*");	
			}
			System.out.println();
		}
	}
	static int largest(int a,int b,int c) {
		if(a>b&&b>c) {
			return("largest:" + a);
		}
	}

}
